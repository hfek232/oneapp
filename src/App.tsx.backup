import { Suspense, lazy } from "react";
import { BrowserRouter as Router, Routes, Route } from "react-router-dom";
import { Toaster } from "@/components/ui/toaster";

const Home = lazy(() => import("./Home"));
const Auth = lazy(() => import("./AuthComponent"));
const PrivacyPolicy = lazy(() => import("./PrivacyPolicy"));
const DataDeletion = lazy(() => import("./DataDeletion"));

const LoadingScreen = () => (
  <div className="h-screen w-full flex items-center justify-center bg-black">
    <div className="flex flex-col items-center gap-4">
      <div className="animate-spin h-8 w-8 border-4 border-cyan-500 border-t-transparent rounded-full"></div>
      <div className="animate-pulse text-cyan-400 font-bold tracking-[0.2em] text-xl">ONEAPP</div>
    </div>
  </div>
);

function App() {
  return (
    <Router>
      <Suspense fallback={<LoadingScreen />}>
        <Routes>
          <Route path="/" element={<Home />} />
          <Route path="/auth" element={<Auth />} />
          <Route path="/privacy" element={<PrivacyPolicy />} />
          <Route path="/delete-account" element={<DataDeletion />} />
        </Routes>
      </Suspense>
      <Toaster />
    </Router>
  );
}

export default App;