import React, { useState } from 'react';
import { Home, Tv, ShoppingBag, MessageCircle, User } from 'lucide-react';
import { ProductGrid } from "./product-grid";
import { DealsView } from "./DealsNav";
import { ProfileView } from "./profile-view";
import { Header } from "./header";

export function BottomNav() {
  const [activeTab, setActiveTab] = useState('home');

  const tabs = [
    { id: 'home', label: 'Home', icon: Home },
    { id: 'streams', label: 'Streams', icon: Tv },
    { id: 'sale', label: 'Sale', icon: ShoppingBag },
    { id: 'chat', label: 'Chat', icon: MessageCircle, badge: 12 },
    { id: 'you', label: 'You', icon: User },
  ];

  // This handles the INSTANT view swap
  const renderActiveView = () => {
    switch (activeTab) {
      case 'home': return <div className="p-4 pb-20"><ProductGrid /></div>;
      case 'sale': return <DealsView />;
      case 'you': return <ProfileView />;
      default: return <div className="p-4 pb-20"><ProductGrid /></div>;
    }
  };

  return (
    <div className="min-h-screen bg-[#f7f7f7] flex flex-col">
      {/* Show Header only on Home/Sale */}
      {activeTab !== 'you' && <Header />}
      
      <main className="flex-1 overflow-y-auto">
        {renderActiveView()}
      </main>

      <nav className="fixed bottom-0 left-0 right-0 bg-white border-t flex justify-around items-center h-16 pb-safe z-50">
        {tabs.map((tab) => {
          const Icon = tab.icon;
          const isActive = activeTab === tab.id;
          
          return (
            <button 
              key={tab.id} 
              onClick={() => setActiveTab(tab.id)} 
              className="flex flex-col items-center justify-center flex-1 transition-all"
            >
              <div className={`relative p-1.5 rounded-full ${isActive && tab.id === 'you' ? "bg-[#e02e24] text-white" : ""}`}>
                <Icon 
                  size={isActive && tab.id === 'you' ? 20 : 24} 
                  className={isActive && tab.id !== 'you' ? "text-[#e02e24]" : isActive && tab.id === 'you' ? "text-white" : "text-slate-500"} 
                  fill={isActive ? "currentColor" : "none"}
                />
                {tab.badge && !isActive && (
                  <span className="absolute -top-1 -right-2 bg-[#e02e24] text-white text-[9px] font-bold rounded-full h-4 w-4 flex items-center justify-center border-2 border-white">
                    {tab.badge}
                  </span>
                )}
              </div>
              <span className={`text-[10px] mt-0.5 ${isActive ? "text-[#e02e24] font-bold" : "text-slate-500"}`}>
                {tab.label}
              </span>
            </button>
          );
        })}
      </nav>
    </div>
  );
}
