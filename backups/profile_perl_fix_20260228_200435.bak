import React, { useEffect, useState } from 'react';
import { supabase } from '../lib/supabase';
import { 
  Settings, Wallet, Package, 
  Send, Phone, ChevronRight, CheckCircle2, 
  MapPin, ShoppingBag, Star, Share2 
} from 'lucide-react';

export function ProfileView() {
  const [profile, setProfile] = useState<any>(null);

  useEffect(() => {
    async function getProfile() {
      const { data: { user } } = await supabase.auth.getUser();
      if (user) {
        const { data } = await supabase.from('profiles').select('*').eq('id', user.id).single();
        setProfile(data || { full_name: 'Finkisa Glomsa' });
      }
    }
    getProfile();
  }, []);

  return (
    <div className="bg-[#f0f2f5] min-h-screen pb-24 font-sans">
      {/* 1. TikTok-Style Header (Familiar to Ethio users) */}
      <div className="bg-white px-6 pt-10 pb-6 rounded-b-[30px] shadow-sm">
        <div className="flex flex-col items-center">
          <div className="relative">
            <div className="w-24 h-24 bg-gradient-to-tr from-[#e02e24] to-orange-400 rounded-full flex items-center justify-center text-white text-3xl font-bold border-4 border-white shadow-lg">
              {profile?.full_name?.charAt(0) || 'E'}
            </div>
            <div className="absolute bottom-1 right-1 bg-blue-500 text-white rounded-full p-1 border-2 border-white">
              <CheckCircle2 size={14} />
            </div>
          </div>
          <h2 className="mt-3 text-xl font-bold text-slate-900">{profile?.full_name}</h2>
          <p className="text-sm text-slate-500">Verified Buyer / የታመነ ገዢ</p>
          
          <div className="flex gap-6 mt-4 w-full justify-center border-t pt-4">
            <div className="text-center">
              <p className="font-bold text-lg">0</p>
              <p className="text-[10px] text-slate-400 uppercase tracking-wider">Orders</p>
            </div>
            <div className="w-[1px] bg-slate-100 h-8 mt-1"></div>
            <div className="text-center">
              <p className="font-bold text-lg text-[#e02e24]">ETB 0</p>
              <p className="text-[10px] text-slate-400 uppercase tracking-wider">Wallet</p>
            </div>
            <div className="w-[1px] bg-slate-100 h-8 mt-1"></div>
            <div className="text-center">
              <p className="font-bold text-lg">12</p>
              <p className="text-[10px] text-slate-400 uppercase tracking-wider">Saved</p>
            </div>
          </div>
        </div>
      </div>

      {/* 2. Amazon-Lite Grid (Clean & Big) */}
      <div className="mx-4 mt-4 bg-white rounded-2xl p-4 shadow-sm">
        <h3 className="font-bold text-xs text-slate-400 uppercase mb-4 ml-1">My Activity / የእኔ እንቅስቃሴ</h3>
        <div className="grid grid-cols-4 gap-2">
          <MenuIcon icon={<Package className="text-blue-500" />} label="Shipping" />
          <MenuIcon icon={<ShoppingBag className="text-orange-500" />} label="Bought" />
          <MenuIcon icon={<Star className="text-yellow-500" />} label="Reviews" />
          <MenuIcon icon={<MapPin className="text-green-500" />} label="Address" />
        </div>
      </div>

      {/* 3. Telegram/Facebook Style List (Trust-Building) */}
      <div className="mx-4 mt-4 bg-white rounded-2xl overflow-hidden shadow-sm mb-6">
        <ListItem icon={<Wallet size={20} className="text-orange-500" />} label="Withdraw to Telebirr / CBE" />
        <ListItem 
           icon={<Send size={20} className="text-[#24A1DE]" />} 
           label="Join Telegram Channel" 
           onClick={() => window.open('https://t.me/yourchannel', '_blank')}
        />
        <ListItem icon={<Phone size={20} className="text-green-500" />} label="Call Support / ደውሉልን" />
        <ListItem icon={<Share2 size={20} className="text-purple-500" />} label="Invite Friends & Earn" />
        <ListItem icon={<Settings size={20} className="text-slate-400" />} label="Settings" last />
      </div>
    </div>
  );
}

function MenuIcon({ icon, label }: any) {
  return (
    <div className="flex flex-col items-center gap-2 py-2 active:bg-slate-50 transition-colors rounded-lg">
      <div className="p-2 bg-slate-50 rounded-full">{icon}</div>
      <span className="text-[10px] font-semibold text-slate-600">{label}</span>
    </div>
  );
}

function ListItem({ icon, label, last, onClick }: any) {
  return (
    <div 
      onClick={onClick}
      className={`flex items-center justify-between p-4 active:bg-slate-50 cursor-pointer ${!last ? 'border-b border-slate-50' : ''}`}
    >
      <div className="flex items-center gap-3">
        {icon}
        <span className="text-sm font-medium text-slate-700">{label}</span>
      </div>
      <ChevronRight size={16} className="text-slate-300" />
    </div>
  );
}
